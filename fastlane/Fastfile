default_platform(:ios)

# All authentication uses an App Store Connect API key (.p8), loaded from
# environment variables so no secrets live in the repo. Set these before running
# (e.g. in ~/.zshrc or a local, git-ignored fastlane/.env):
#
#   export ASC_KEY_ID="XXXXXXXXXX"          # the key's Key ID
#   export ASC_ISSUER_ID="aaaa-bbbb-...."   # Issuer ID (top of the API Keys page)
#   export ASC_KEY_PATH="$HOME/.appstoreconnect/private/AuthKey_XXXXXXXXXX.p8"
#
# Create the key in App Store Connect → Users and Access → Integrations →
# App Store Connect API → generate a key with "App Manager" access.

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: File.expand_path(ENV.fetch("ASC_KEY_PATH")),
    in_house: false
  )
end

platform :ios do
  # Push ONLY the text metadata (name, subtitle, description, keywords,
  # promotional text, what's-new, URLs, copyright, category) to App Store
  # Connect. No build, no screenshots touched. Great for fast copy edits.
  desc "Push App Store metadata only (no build, no screenshots)"
  lane :metadata do
    upload_to_app_store(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: false,
      run_precheck_before_submit: false,
      force: true # don't open the HTML preview / wait for confirmation
    )
  end

  # Build a Release archive and upload it to TestFlight.
  desc "Build and upload a TestFlight build"
  lane :beta do
    build_app(
      project: "Aether.xcodeproj",
      scheme: "Aether",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build-fastlane",
      clean: true
    )
    upload_to_testflight(
      api_key: asc_api_key,
      skip_waiting_for_build_processing: true
    )
  end

  # The full one-command release: archive, upload the build, push all metadata,
  # and submit for review. Release to the store happens automatically on approval.
  desc "Build, upload, push metadata, and submit for App Store review"
  lane :release do
    build_app(
      project: "Aether.xcodeproj",
      scheme: "Aether",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build-fastlane",
      clean: true
    )
    upload_to_app_store(
      api_key: asc_api_key,
      skip_screenshots: true,        # screenshots are managed by hand in ASC
      submit_for_review: true,
      automatic_release: true,       # go live automatically once approved
      run_precheck_before_submit: true,
      precheck_include_in_app_purchases: false,
      force: true,
      submission_information: {
        # Aether has no encryption, no ads, no third-party content.
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false
      }
    )
  end
end
